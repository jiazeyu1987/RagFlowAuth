{
  "name": "auth-frontend",
  "version": "1.0.0",
  "description": "Auth management frontend for RagInt",
  "private": true,
  "dependencies": {
    "axios": "^1.6.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.11.0",
    "pdfjs-dist": "^5.4.530",
    "react": "^18.2.0",
    "react-diff-viewer-continued": "^4.0.6",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1"
  },
  "scripts": {
    "start": "node -e \"process.env.PORT='3001'; require('react-scripts/scripts/start')\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "e2e": "playwright test --grep-invert @integration && npm run e2e:integration:nonrealdata && npm run e2e:realdata:strict",
    "e2e:strict": "npm run e2e",
    "e2e:all": "playwright test",
    "e2e:realdata": "playwright test --grep @realdata --workers=1",
    "e2e:realdata:strict": "python ../scripts/run_realdata_e2e.py --strict --fronted-dir .",
    "e2e:smoke": "playwright test --grep @smoke",
    "e2e:integration": "playwright test --grep @integration --workers=1",
    "e2e:integration:nonrealdata": "playwright test --grep @integration --grep-invert @realdata --workers=1",
    "e2e:report": "playwright show-report",
    "e2e:ui": "playwright test --ui",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
